{
  "manifest_version": 3,
  "name": "Focus — Digital Wellbeing",
  "version": "0.3.0",
  "description": "Track your web usage and block distracting websites.",
  "permissions": ["storage", "tabs", "idle", "webNavigation", "alarms"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Focus"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/enforcer.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/youtube-focus.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["blocked.html", "popup/assets/*", "content/youtube/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
